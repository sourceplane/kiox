apiVersion: tinx.io/v1
kind: Provider
metadata:
  namespace: sourceplane
  name: echo-provider
  version: v0.1.0
  description: Test provider for tinx packaging and installation
spec:
  runtime: binary
  entrypoint: echo-provider
  platforms:
    - os: darwin
      arch: amd64
      binary: bin/darwin/amd64/echo-provider
    - os: darwin
      arch: arm64
      binary: bin/darwin/arm64/echo-provider
    - os: linux
      arch: amd64
      binary: bin/linux/amd64/echo-provider
    - os: linux
      arch: arm64
      binary: bin/linux/arm64/echo-provider
  capabilities:
    plan:
      description: Generate a plan
  layers:
    assets:
      root: assets
