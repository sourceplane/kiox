    "validate": "Validate intent and component definitions"
  },
  "platforms": [
    {
      "os": "darwin",
      "arch": "amd64",
      "binary": "bin/darwin/amd64/entrypoint"
    },
    {
      "os": "darwin",
      "arch": "arm64",
      "binary": "bin/darwin/arm64/entrypoint"
    },
    {
      "os": "linux",
      "arch": "amd64",
      "binary": "bin/linux/amd64/entrypoint"
    },
    {
      "os": "linux",
      "arch": "arm64",
      "binary": "bin/linux/arm64/entrypoint"
    }
  ]
